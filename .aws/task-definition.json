{
    
    "containerDefinitions": [
        {
            "name": "students-performance-cluster",
            "image": "455023172982.dkr.ecr.eu-north-1.amazonaws.com/student-performance-app:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "students-performance-cluster-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/students-performance-cluster",
                    "awslogs-create-group": "true",
                    "awslogs-region": "eu-north-1",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "students-performance-cluster",
    "executionRoleArn": "arn:aws:iam::455023172982:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    
    "volumes": [],
    
    "placementConstraints": [],
  
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "3072",
   
    
}
